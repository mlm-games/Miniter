<component type="desktop-application">
  <id>io.github.mlm_games.miniter</id>
  <name>Miniter</name>
  <summary>Extemely Basic Video editor</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-only</project_license>
  <developer id="io.github.mlm_games">
    <name>MLM Games</name>
  </developer>
  <description>
    <p>
      Miniter is an basic video editor built for simple video editing tasks that doesn't aim to have features similar to complex editors, mostly for casual tasks. Has a simpler UI compared to most other video editors.
    </p>
  </description>
  <launchable type="desktop-id">io.github.mlm_games.miniter.desktop</launchable>
