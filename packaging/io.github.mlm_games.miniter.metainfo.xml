<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.mlm_games.miniter</id>
  <name>Miniter</name>
  <summary>Extemely Basic Video editor</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-only</project_license>
  <developer id="io.github.mlm_games">
    <name>MLM Games</name>
  </developer>
  <description>
    <p>
      Miniter is an basic video editor built for simple video editing tasks. Has a simpler UI compared to most other video editors.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Video editing capabilities</li>
      <li>Cross-platform support (Windows, macOS, Linux, Android)</li>
      <li>Modern Material Design 3 UI</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.mlm_games.miniter.desktop</launchable>
  <url type="homepage">https://github.com/mlm-games/miniter</url>
  <url type="bugtracker">https://github.com/mlm-games/miniter/issues</url>
  <url type="vcs-browser">https://github.com/mlm-games/miniter</url>
  <branding>
    <color type="primary" scheme_preference="light">#6750A4</color>
    <color type="primary" scheme_preference="dark">#D0BCFF</color>
  </branding>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="0.5.3" date="2026-02-26" type="stable">
      <description>
        <ul>
          <li>transitions work on desktop only, even text</li>
          <li>multi layer overlay test (jvm works, android partial)</li>
          <li>Fix android saving once again!</li>
          <li>add all the boilerplate rel. stuff</li>
          <li>icon</li>
          <li>Transitions, fill blank space with black bg, and fix project load</li>
          <li>Multi track clipping fix for android</li>
          <li>Fix filters for android</li>
          <li>add error track printing</li>
          <li>File saving logic fix</li>
          <li>android URI handling 1</li>
          <li>fix android crash</li>
          <li>Text rendering, and audio export on jvm</li>
          <li>It exports tracks with filters!</li>
          <li>Add import button back</li>
          <li>Much better timeline sync (although it needs to be paused in between)</li>
          <li>add some logging</li>
          <li>add supported format, auto save wiring, android fixes, and others</li>
          <li>Some more UI changes to wire later</li>
          <li>Export screen wiring (UI only)</li>
          <li>It works when video is paused and changes are made (trial 3 for video preview sync)</li>
          <li>trial 2 for video preview sync</li>
          <li>trial 1 for video preview sync</li>
          <li>refactor for mobile first UI</li>
          <li>add panel before refactor</li>
          <li>Add partial project dialog</li>
          <li>Add import button for more files, for a project, and basic audio wiring</li>
          <li>moving b/w tracks works</li>
          <li>Make preview speed actually go in the right direction</li>
          <li>fix clip snaps, and other minor issues</li>
          <li>Undo redo, opacity, and recent projects wiring</li>
          <li>Add icon</li>
          <li>Better timelines</li>
          <li>Text displays somewhat, mediaplayer doesn't react to few changes inbetween</li>
          <li>android impl + setup extends (like )Uuid</li>
          <li>jvm plays, rest -&gt; placeholders</li>
          <li>save copy</li>
        </ul>
      </description>
    </release>
